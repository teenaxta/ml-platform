# ============================================================
#  .env.example  —  copy to .env and change every password
#  NEVER commit .env to version control
# ============================================================

# ── MinIO (object storage) ───────────────────────────────────
MINIO_ROOT_USER=mlplatform
MINIO_ROOT_PASSWORD=MinioSecure123

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=AirflowDB456
AIRFLOW_ADMIN_PASSWORD=AirflowAdmin789
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=DfPsR4x11s_Z9EQKW9nhciUHhjVBG4UqjMOyLB-9OB8=
AIRFLOW_SECRET_KEY=AirflowSecret321

# ── JupyterHub ───────────────────────────────────────────────
JUPYTERHUB_ADMIN_USER=admin
JUPYTERHUB_ADMIN_PASSWORD=JupyterAdmin999
JUPYTERHUB_DB_PASSWORD=JupyterDB111

# ── Feast ────────────────────────────────────────────────────
FEAST_DB_PASSWORD=FeastDB222

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_DB_PASSWORD=MLflowDB333
# Admin user created on first boot (change immediately after first login)
MLFLOW_ADMIN_USERNAME=admin
MLFLOW_ADMIN_PASSWORD=MLflowAdmin777
# Secret key for CSRF protection — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
MLFLOW_FLASK_SECRET_KEY=changeme-generate-a-real-secret-with-secrets-token-hex

# ── Spark worker resources (tune to your GPU server) ─────────
SPARK_WORKER_MEMORY=16G
SPARK_WORKER_CORES=8
